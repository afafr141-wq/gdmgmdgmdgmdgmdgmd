# MEXC API
MEXC_API_KEY=your_mexc_api_key
MEXC_API_SECRET=your_mexc_api_secret

# Telegram
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
TELEGRAM_CHAT_ID=your_telegram_chat_id

# Supabase / PostgreSQL
DATABASE_URL=postgresql://postgres.qeipuafxoqdeauemgsxb:Kabokingkaboking@aws-1-eu-central-1.pooler.supabase.com:6543/postgres

# Logging
LOG_LEVEL=INFO

# SuperConsensus AI Judge (OpenRouter)
OPENROUTER_API_KEY=your_openrouter_api_key
OPENROUTER_MODEL=nvidia/nemotron-3-super-120b-a12b:free
AI_JUDGE_INTERVAL_MINUTES=10

# Smart Scanner (optional overrides)
# SCAN_COIN_COUNT=50   # number of top coins to scan (10-100, default 50)

# ── Copy-trade (BSC / PancakeSwap V2 + GMGN) ──────────────────────────────────
# BSCScan API key — get free key at https://bscscan.com/myapikey
BSCSCAN_API_KEY=your_bscscan_api_key
# Ankr WebSocket endpoint (wss://)
# Option A — key-in-URL (Ankr, public Chainstack endpoint):
BSC_WS_RPC_URL=wss://rpc.ankr.com/bsc/ws/your_ankr_key_here
# Option B — password-protected endpoint (Chainstack "Password-protected" section):
# BSC_WS_RPC_URL=wss://bsc-mainnet.core.chainstack.com/your_endpoint_id
# BSC_WS_USERNAME=admiring-roentgen
# BSC_WS_PASSWORD=your_chainstack_password
# Ankr HTTP endpoint (https://)
BSC_HTTP_RPC_URL=https://rpc.ankr.com/bsc/your_ankr_key_here
# Target wallet to copy (supports PancakeSwap V2 and GMGN router)
COPY_TARGET_WALLET=0x7e8fb0392542812476d9f2d0d71c01d1fa0776c5
# Your BSC wallet private key (keep secret, never commit)
MY_BSC_PRIVATE_KEY=your_bsc_private_key_here
# Trade size per copied swap in USDT
COPY_TRADE_USDT=3
# Copy sell transactions too (true/false)
COPY_SELLS=true
# Enable copy trading on startup (true/false)
COPY_TRADE_ENABLED=true
